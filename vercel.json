{
  "version": 2,
  "functions": {
    "api/create-payment.js":  { "maxDuration": 30 },
    "api/payment-webhook.js": { "maxDuration": 30 },
    "api/broadcast.js":       { "maxDuration": 60 },
    "api/marketing-agent.js": { "maxDuration": 60 },
    "api/support-bot.js":     { "maxDuration": 30 },
    "api/referral.js":        { "maxDuration": 10 },
    "api/analytics.js":       { "maxDuration": 10 },
    "api/gnews.js":           { "maxDuration": 15 },
    "api/email-drip.js":      { "maxDuration": 120 }
  },
  "crons": [
    {
      "path": "/api/marketing-agent",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/email-drip?action=run-drip",
      "schedule": "0 3 * * *"
    }
  ],
  "routes": [
    { "src": "/api/(.*)",         "dest": "/api/$1" },
    { "src": "/sitemap.xml",      "dest": "/public/sitemap.xml" },
    { "src": "/robots.txt",       "dest": "/public/robots.txt" },
    { "src": "/.well-known/(.*)", "dest": "/public/.well-known/$1" },
    { "src": "/privacy",          "dest": "/public/privacy.html" },
    { "src": "/terms",            "dest": "/public/terms.html" },
    { "src": "/pro",              "dest": "/pro.html" },
    { "src": "/alerts",           "dest": "/alerts.html" },
    { "src": "/feed",             "dest": "/index.html" },
    { "src": "/",                 "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",      "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/.well-known/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "Content-Type",  "value": "application/json" }
      ]
    }
  ]
}
