{
  "version": 2,
  "rewrites": [
    { "source": "/api/create-payment",  "destination": "/create-payment.js" },
    { "source": "/api/payment-webhook", "destination": "/payment-webhook.js" },
    { "source": "/pro",                 "destination": "/pro.html" },
    { "source": "/alerts",              "destination": "/alerts.html" },
    { "source": "/privacy",             "destination": "/privacy.html" },
    { "source": "/terms",               "destination": "/terms.html" },
    { "source": "/feed",                "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
