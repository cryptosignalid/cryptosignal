{
  "version": 2,
  "routes": [
    { "src": "/sitemap.xml",         "dest": "/sitemap.xml" },
    { "src": "/robots.txt",          "dest": "/robots.txt" },
    { "src": "/.well-known/(.*)",    "dest": "/.well-known/$1" },
    { "src": "/privacy",             "dest": "/privacy.html" },
    { "src": "/terms",               "dest": "/terms.html" },
    { "src": "/pro",                 "dest": "/pro.html" },
    { "src": "/alerts",              "dest": "/alerts.html" },
    { "src": "/feed",                "dest": "/index.html" },
    { "src": "/api/(.*)",            "dest": "/api/$1" },
    { "src": "/(.*)",                "dest": "/index.html" }
  ]
}
