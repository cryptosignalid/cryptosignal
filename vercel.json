{
  "version": 2,
  "functions": {
    "create-payment.js":  { "maxDuration": 30 },
    "payment-webhook.js": { "maxDuration": 30 },
    "broadcast.js":       { "maxDuration": 60 }
  },
  "routes": [
    { "src": "/api/create-payment",  "dest": "/create-payment.js" },
    { "src": "/api/payment-webhook", "dest": "/payment-webhook.js" },
    { "src": "/api/broadcast",       "dest": "/broadcast.js" },
    { "src": "/sitemap.xml",         "dest": "/sitemap.xml" },
    { "src": "/robots.txt",          "dest": "/robots.txt" },
    { "src": "/.well-known/(.*)",    "dest": "/.well-known/$1" },
    { "src": "/privacy",             "dest": "/privacy.html" },
    { "src": "/terms",               "dest": "/terms.html" },
    { "src": "/pro",                 "dest": "/pro.html" },
    { "src": "/alerts",              "dest": "/alerts.html" },
    { "src": "/feed",                "dest": "/index.html" },
    { "src": "/(.*)",                "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
