{
  "version": 2,
  "functions": {
    "api/create-payment.js":  { "maxDuration": 30 },
    "api/payment-webhook.js": { "maxDuration": 30 },
    "api/broadcast.js":       { "maxDuration": 60 },
    "api/daily-digest.js":    { "maxDuration": 60 },
    "api/generate-media.js":  { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/daily-digest",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/generate-media",
      "schedule": "30 1 * * *"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/pro",      "dest": "/pro.html" },
    { "src": "/",         "dest": "/index.html" }
  ]
}
